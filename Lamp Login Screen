private val BG_TOP      = Color(0xFF080A0F)
private val BG_BOT      = Color(0xFF0E1118)
private val SHADE_OFF   = Color(0xFF1E2028)
private val SHADE_ON    = Color(0xFFB8965A)
private val SHADE_LIT   = Color(0xFFFFE0A0)
private val POLE_COL    = Color(0xFF888888)
private val BASE_COL    = Color(0xFFAAAAAA)
private val CORD_COL    = Color(0xFF888888)
private val KNOB_COL    = Color(0xFFAAAAAA)
private val GLOW_WARM   = Color(0xFFFFD060)
private val ACCENT      = Color(0xFFFFB347)
private val CARD_BG     = Color(0xFF12151C)
private val INPUT_BG    = Color(0xFF1A1E28)
private val HINT_COL    = Color(0xFF4A5068)

// Face colors
private val SKIN_COL    = Color(0xFFFFD59E)
private val SKIN_DARK   = Color(0xFFE5B880)
private val EYE_WHITE   = Color(0xFFFFF8F0)
private val EYE_IRIS    = Color(0xFF4A90D9)
private val EYE_PUPIL   = Color(0xFF1A1A1A)
private val BROW_COL    = Color(0xFF6B4C2A)
private val MOUTH_COL   = Color(0xFFCC6655)
private val TEETH_COL   = Color(0xFFFFFAF5)
